{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Folder picker plus read/write of Markdown files inside the user's home tree (vault).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:scope-home-recursive"
  ]
}
